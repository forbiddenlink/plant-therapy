{
  "name": "plant-therapy",
  "version": "1.0.0",
  "description": "A responsive wellness blog about plant care and mental health, built with Tailwind CSS. Features dark mode, form validation, smooth animations, and full accessibility support.",
  "keywords": [
    "tailwind-css",
    "responsive-design",
    "dark-mode",
    "wellness",
    "plant-care",
    "mental-health",
    "portfolio-project",
    "html5",
    "css3",
    "javascript"
  ],
  "author": "Plant Therapy",
  "license": "MIT",
  "homepage": "https://github.com/forbiddenlink/plant-therapy#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forbiddenlink/plant-therapy.git"
  },
  "bugs": {
    "url": "https://github.com/forbiddenlink/plant-therapy/issues"
  },
  "scripts": {
    "start": "npx http-server . -o",
    "serve": "npx http-server . -p 3000",
    "preview": "npx http-server . -o -c-1",
    "biome:check": "biome check .",
    "biome:fix": "biome check . --write",
    "biome:format": "biome format . --write"
  },
  "dependencies": {
    "http-server": "^14.1.1"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@testing-library/react": "^16.3.2",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.3",
      "vite": ">=6.4.2"
    }
  }
}
